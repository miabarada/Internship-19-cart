{
   "$schema": "https://turborepo.org/schema.json",
   "globalPassThroughEnv": [
      "VITE_API_URL"
   ],
   "tasks": {
      "dev": {
         "cache": false
      },
      "build": {
         "dependsOn": [
            "^build"
         ],
         "env": [
            "VITE_API_URL"
         ],
         "outputs": [
            "dist/**"
         ]
      }
   }
}